{% doc %}
  @prompt
    simple div
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-simple-div-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    min-height: {{ block.settings.min_height }}px;
  }
  .brush-paint{
    background-image: url('{{ "brush.png" | asset_url }}');
    background-size: 100%;
    height: 120px;
    width: 100%;
    color: #000000;
    position: absolute;
    bottom: 0;
    margin-bottom: -30px;
    background-position: center;
    background-repeat: no-repeat;
  }

  .ai-simple-div-content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  @media (max-width: 768px){
    .brush-paint{
       margin-bottom: 10px;
    }
  }
{% endstyle %}

<simple-div-{{ ai_gen_id }}
  class="ai-simple"
  {{ block.shopify_attributes }}
>
    <div class="brush-paint">
    </div>
</simple-div-{{ ai_gen_id }}>

<script>
  (function() {
    class SimpleDiv{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('simple-div-{{ ai_gen_id }}', SimpleDiv{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Simple div",
  "tag": null,
  "settings": [
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>This is a simple div block</p>"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height",
      "min": 50,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f9f6ef"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Simple div"
    }
  ]
}
{% endschema %}
