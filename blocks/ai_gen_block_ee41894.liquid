{% doc %}
  @prompt
    a green line full width
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-divider-line-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
  }

  .ai-divider-line__inner-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.line_thickness }}px;
    background-color: {{ block.settings.line_color }};
    margin: 0;
  }
{% endstyle %}

<div class="ai-divider-line-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-divider-line__inner-{{ ai_gen_id }}"></div>
</div>

{% schema %}
{
  "name": "Divider line",
  "settings": [
    {
      "type": "color",
      "id": "line_color",
      "label": "Line color",
      "default": "#00ff00"
    },
    {
      "type": "range",
      "id": "line_thickness",
      "label": "Line thickness",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 2
    }
  ],
  "presets": [
    {
      "name": "Divider line"
    }
  ]
}
{% endschema %}
