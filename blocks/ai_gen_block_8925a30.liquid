{% doc %}
  @prompt
    create a sample blog post from the people. this can able to heart and comment to the public. create a sample content for title and description for the journey. blog post should be a sample of atleast 5 sample. with sample image, put a sample image and comment and heart reactions.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-journey-posts-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 28px 20px 52px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-journey-posts__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-journey-posts__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 30px;
  }

  .ai-journey-posts__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 10px;
    line-height: 1.15;
  }

  .ai-journey-posts__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-journey-posts__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
  }

  .ai-journey-post-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_radius }}px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    display: flex;
    flex-direction: column;
  }

  .ai-journey-post-{{ ai_gen_id }}:hover,
  .ai-journey-post-{{ ai_gen_id }}:focus-visible {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.14);
  }

  .ai-journey-post__header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
  }

  .ai-journey-post__avatar-{{ ai_gen_id }} {
    width: 34px;
    height: 34px;
    border-radius: 999px;
    background-color: {{ block.settings.accent_color }};
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .ai-journey-post__author-wrap-{{ ai_gen_id }} {
    min-width: 0;
  }

  .ai-journey-post__author-{{ ai_gen_id }} {
    margin: 0;
    font-size: 13px;
    color: {{ block.settings.text_color }};
    font-weight: 700;
    line-height: 1.2;
  }

  .ai-journey-post__date-{{ ai_gen_id }} {
    margin: 0;
    font-size: 12px;
    color: {{ block.settings.meta_color }};
    line-height: 1.2;
  }

  .ai-journey-post__image-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #e9ece8;
  }

  .ai-journey-post__image-{{ ai_gen_id }} img,
  .ai-journey-post__image-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .ai-journey-post__body-{{ ai_gen_id }} {
    padding: 12px 14px 14px;
  }

  .ai-journey-post__actions-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .ai-journey-post__action-list-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .ai-journey-post__action-btn-{{ ai_gen_id }} {
    border: 0;
    background: transparent;
    padding: 0;
    margin: 0;
    display: inline-flex;
    gap: 6px;
    align-items: center;
    color: {{ block.settings.meta_color }};
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
  }

  .ai-journey-post__action-btn-{{ ai_gen_id }} svg {
    width: 18px;
    height: 18px;
  }

  .ai-journey-post__action-btn-{{ ai_gen_id }}.liked {
    color: {{ block.settings.accent_color }};
  }

  .ai-journey-post__title-{{ ai_gen_id }} {
    margin: 0 0 6px;
    font-size: 15px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    line-height: 1.35;
  }

  .ai-journey-post__caption-{{ ai_gen_id }} {
    margin: 0;
    font-size: 13px;
    color: {{ block.settings.text_color }};
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-journey-post__open-hint-{{ ai_gen_id }} {
    display: inline-flex;
    margin-top: 10px;
    font-size: 12px;
    color: {{ block.settings.meta_color }};
  }

  .ai-journey-modal-{{ ai_gen_id }} {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: none;
    background: rgba(18, 18, 18, 0.78);
    padding: 20px;
    align-items: center;
    justify-content: center;
  }

  .ai-journey-modal-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-journey-modal__panel-{{ ai_gen_id }} {
    width: min(1100px, 100%);
    max-height: calc(100vh - 40px);
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_radius }}px;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
  }

  .ai-journey-modal__media-{{ ai_gen_id }} {
    background: #f2f3ef;
    min-height: 360px;
  }

  .ai-journey-modal__media-{{ ai_gen_id }} img,
  .ai-journey-modal__media-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-journey-modal__content-{{ ai_gen_id }} {
    padding: 20px;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .ai-journey-modal__top-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
    gap: 10px;
  }

  .ai-journey-modal__meta-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    color: {{ block.settings.meta_color }};
    font-size: 13px;
  }

  .ai-journey-modal__close-{{ ai_gen_id }} {
    border: 0;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    background: #f2f2f2;
    color: {{ block.settings.text_color }};
    font-size: 20px;
    cursor: pointer;
  }

  .ai-journey-modal__title-{{ ai_gen_id }} {
    margin: 0 0 8px;
    font-size: 24px;
    line-height: 1.25;
    color: {{ block.settings.text_color }};
  }

  .ai-journey-modal__description-{{ ai_gen_id }} {
    margin: 0 0 14px;
    color: {{ block.settings.text_color }};
    font-size: 14px;
    line-height: 1.6;
  }

  .ai-journey-modal__actions-{{ ai_gen_id }} {
    padding: 10px 0 12px;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    margin-bottom: 12px;
    display: flex;
    gap: 14px;
  }

  .ai-journey-modal__scroll-{{ ai_gen_id }} {
    overflow: auto;
    padding-right: 2px;
  }

  .ai-journey-modal__detail-{{ ai_gen_id }} {
    margin: 0 0 14px;
    color: {{ block.settings.text_color }};
    font-size: 14px;
    line-height: 1.65;
  }

  .ai-journey-modal__comments-title-{{ ai_gen_id }} {
    margin: 0 0 10px;
    font-size: 15px;
    color: {{ block.settings.text_color }};
  }

  .ai-journey-modal__comment-list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 12px;
  }

  .ai-journey-modal__comment-{{ ai_gen_id }} {
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 10px;
    padding: 10px;
    background: #ffffff;
  }

  .ai-journey-modal__comment-head-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 6px;
    font-size: 12px;
    color: {{ block.settings.meta_color }};
  }

  .ai-journey-modal__comment-name-{{ ai_gen_id }} {
    font-weight: 700;
    color: {{ block.settings.text_color }};
  }

  .ai-journey-modal__comment-text-{{ ai_gen_id }} {
    margin: 0;
    font-size: 13px;
    line-height: 1.5;
    color: {{ block.settings.text_color }};
  }

  .ai-journey-modal__empty-{{ ai_gen_id }} {
    margin: 0 0 12px;
    font-size: 13px;
    color: {{ block.settings.meta_color }};
  }

  .ai-journey-modal__form-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 120px 1fr auto;
    gap: 8px;
  }

  .ai-journey-modal__input-{{ ai_gen_id }} {
    width: 100%;
    border: 1px solid rgba(0, 0, 0, 0.2);
    border-radius: 999px;
    padding: 10px 12px;
    font-size: 13px;
    background: #ffffff;
    color: {{ block.settings.text_color }};
  }

  .ai-journey-modal__submit-{{ ai_gen_id }} {
    border: 0;
    border-radius: 999px;
    background: {{ block.settings.accent_color }};
    color: #ffffff;
    font-size: 13px;
    font-weight: 700;
    padding: 10px 14px;
    cursor: pointer;
  }

  .ai-journey-create-{{ ai_gen_id }} {
    margin-top: 28px;
    background: {{ block.settings.card_background }};
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: {{ block.settings.card_radius }}px;
    padding: 18px;
  }

  .ai-journey-create__title-{{ ai_gen_id }} {
    margin: 0 0 6px;
    font-size: 20px;
    color: {{ block.settings.text_color }};
  }

  .ai-journey-create__subtitle-{{ ai_gen_id }} {
    margin: 0 0 14px;
    font-size: 13px;
    color: {{ block.settings.meta_color }};
  }

  .ai-journey-create__form-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1.1fr 1.1fr 2fr auto;
    gap: 10px;
    align-items: end;
  }

  .ai-journey-create__group-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .ai-journey-create__label-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.meta_color }};
    font-weight: 600;
  }

  .ai-journey-create__input-{{ ai_gen_id }},
  .ai-journey-create__textarea-{{ ai_gen_id }} {
    width: 100%;
    border: 1px solid rgba(0, 0, 0, 0.2);
    border-radius: 10px;
    padding: 10px 12px;
    font-size: 13px;
    color: {{ block.settings.text_color }};
    background: #ffffff;
  }

  .ai-journey-create__input-file-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.text_color }};
  }

  .ai-journey-create__textarea-{{ ai_gen_id }} {
    min-height: 44px;
    max-height: 140px;
    resize: vertical;
  }

  .ai-journey-create__submit-{{ ai_gen_id }} {
    border: 0;
    border-radius: 999px;
    padding: 11px 16px;
    background: {{ block.settings.accent_color }};
    color: #ffffff;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
  }

  .ai-journey-create__status-{{ ai_gen_id }} {
    margin: 10px 0 0;
    font-size: 12px;
    color: {{ block.settings.meta_color }};
    min-height: 16px;
  }

  @media screen and (max-width: 1024px) {
    .ai-journey-posts__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .ai-journey-modal__panel-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      max-height: calc(100vh - 24px);
    }

    .ai-journey-modal__media-{{ ai_gen_id }} {
      max-height: 42vh;
    }

    .ai-journey-create__form-{{ ai_gen_id }} {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-journey-posts-{{ ai_gen_id }} {
      padding: 18px 12px 38px;
    }

    .ai-journey-posts__header-{{ ai_gen_id }} {
      margin-bottom: 18px;
    }

    .ai-journey-posts__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .ai-journey-modal-{{ ai_gen_id }} {
      padding: 8px;
    }

    .ai-journey-modal__content-{{ ai_gen_id }} {
      padding: 14px;
    }

    .ai-journey-modal__title-{{ ai_gen_id }} {
      font-size: 20px;
    }

    .ai-journey-modal__form-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-journey-create-{{ ai_gen_id }} {
      margin-top: 18px;
      padding: 14px;
    }

    .ai-journey-create__form-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<journey-posts-{{ ai_gen_id }} class="ai-journey-posts-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-journey-posts__container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank %}
      <div class="ai-journey-posts__header-{{ ai_gen_id }}">
        <h2 class="ai-journey-posts__title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
        {% if block.settings.section_subtitle != blank %}
          <p class="ai-journey-posts__subtitle-{{ ai_gen_id }}">{{ block.settings.section_subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% assign posts = '
      [
        {
          "author": "Sarah Mitchell",
          "initials": "SM",
          "date": "March 15, 2026",
          "title": "Sunrise Push at Ben Nevis",
          "description": "Chased sunrise to the summit and captured one of the clearest ridge views this season.",
          "detail": "We started before 4:00 AM and moved steady through changing weather. The final ascent was icy, but the sky opened just as we reached the top. This trip reminded me that timing, patience, and a strong team make all the difference on hard routes.",
          "image_url": "https://picsum.photos/seed/ro-blog-1/900/900",
          "likes": 127,
          "isLiked": true,
          "comments": [
            {"author": "James", "text": "That sunrise shot is unreal.", "date": "Mar 16"},
            {"author": "Emma", "text": "Adding this route to my list.", "date": "Mar 17"}
          ]
        },
        {
          "author": "Marcus Chen",
          "initials": "MC",
          "date": "March 18, 2026",
          "title": "Cornwall Coastal Switchbacks",
          "description": "Windy ridge line, rough terrain, and the bluest water I have seen this year.",
          "detail": "The western trail had steep switchbacks and loose stone sections, so poles were essential. We paused often because the cliff views were too good to rush. If you do this route, start early and pack layers for quick weather swings.",
          "image_url": "https://picsum.photos/seed/ro-blog-2/900/900",
          "likes": 93,
          "isLiked": false,
          "comments": [
            {"author": "Lucy", "text": "Looks like a perfect weekend run.", "date": "Mar 19"}
          ]
        },
        {
          "author": "Olivia Thompson",
          "initials": "OT",
          "date": "March 20, 2026",
          "title": "Highlands Wild Camp Setup",
          "description": "Three nights off-grid with cold mornings, clear nights, and incredible silence.",
          "detail": "Camped above the tree line with a low profile tent to handle wind exposure. The second night dropped below freezing, but the setup held and we woke up to a full valley cloud inversion. This is the kind of trip that resets your pace.",
          "image_url": "https://picsum.photos/seed/ro-blog-3/900/900",
          "likes": 156,
          "isLiked": true,
          "comments": [
            {"author": "Tom", "text": "What sleeping bag rating did you use?", "date": "Mar 21"},
            {"author": "Alex", "text": "Cloud inversion looks insane.", "date": "Mar 22"}
          ]
        },
        {
          "author": "David Roberts",
          "initials": "DR",
          "date": "March 22, 2026",
          "title": "Welsh Trail Bike Session",
          "description": "Fast descents, technical corners, and one very muddy finish line.",
          "detail": "The upper section was mostly rock gardens and tight turns, so speed control mattered more than power. We rode three loops and adjusted tire pressure between runs to improve grip. Legs were cooked by the last descent.",
          "image_url": "https://picsum.photos/seed/ro-blog-4/900/900",
          "likes": 104,
          "isLiked": false,
          "comments": [
            {"author": "Mike", "text": "Need the GPX for this route.", "date": "Mar 23"}
          ]
        },
        {
          "author": "Hannah Wilson",
          "initials": "HW",
          "date": "March 24, 2026",
          "title": "Windermere Kayak Drift",
          "description": "Glassy water before noon and mountain reflections all day.",
          "detail": "Started from the north shore and kept close to the lee side to avoid crosswind in open water. The lake stayed calm for most of the route, which made photography easy. Ended with a short portage and hot coffee by sunset.",
          "image_url": "https://picsum.photos/seed/ro-blog-5/900/900",
          "likes": 118,
          "isLiked": true,
          "comments": [
            {"author": "Rachel", "text": "This color palette is beautiful.", "date": "Mar 24"},
            {"author": "Chris", "text": "Morning water looked perfect.", "date": "Mar 25"}
          ]
        },
        {
          "author": "Priya Nair",
          "initials": "PN",
          "date": "March 25, 2026",
          "title": "Forest Loop Recovery Hike",
          "description": "Easy pace, long trail chat, and a lot of fern-lined paths.",
          "detail": "After two intense weekends, we planned a recovery day with lighter packs and frequent breaks. The route stayed mostly shaded and had several stream crossings that kept it cool throughout the afternoon. Sometimes slower is exactly right.",
          "image_url": "https://picsum.photos/seed/ro-blog-6/900/900",
          "likes": 79,
          "isLiked": false,
          "comments": [
            {"author": "Nico", "text": "Need more low-intensity routes like this.", "date": "Mar 26"}
          ]
        }
      ]
    ' | strip %}

    {% assign posts_array = posts | parse_json %}

    <div class="ai-journey-posts__grid-{{ ai_gen_id }}" data-posts-grid></div>

    <div class="ai-journey-modal-{{ ai_gen_id }}" data-post-modal aria-hidden="true">
      <div class="ai-journey-modal__panel-{{ ai_gen_id }}" role="dialog" aria-modal="true" aria-label="Blog post details">
        <div class="ai-journey-modal__media-{{ ai_gen_id }}" data-modal-media></div>

        <div class="ai-journey-modal__content-{{ ai_gen_id }}">
          <div class="ai-journey-modal__top-{{ ai_gen_id }}">
            <div class="ai-journey-modal__meta-{{ ai_gen_id }}">
              <strong data-modal-author></strong>
              <span>•</span>
              <span data-modal-date></span>
            </div>
            <button type="button" class="ai-journey-modal__close-{{ ai_gen_id }}" data-modal-close aria-label="Close details">&times;</button>
          </div>

          <h3 class="ai-journey-modal__title-{{ ai_gen_id }}" data-modal-title></h3>
          <p class="ai-journey-modal__description-{{ ai_gen_id }}" data-modal-description></p>

          <div class="ai-journey-modal__actions-{{ ai_gen_id }}">
            <button type="button" class="ai-journey-post__action-btn-{{ ai_gen_id }}" data-modal-like-btn aria-pressed="false">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
              </svg>
              <span data-modal-like-count>0</span>
            </button>

            <span class="ai-journey-post__action-btn-{{ ai_gen_id }}" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
              </svg>
              <span data-modal-comment-count>0</span>
            </span>
          </div>

          <div class="ai-journey-modal__scroll-{{ ai_gen_id }}">
            <p class="ai-journey-modal__detail-{{ ai_gen_id }}" data-modal-detail></p>
            <h4 class="ai-journey-modal__comments-title-{{ ai_gen_id }}">Comments</h4>
            <div class="ai-journey-modal__comment-list-{{ ai_gen_id }}" data-modal-comments></div>
            <p class="ai-journey-modal__empty-{{ ai_gen_id }}" data-modal-empty>No comments yet.</p>

            <form class="ai-journey-modal__form-{{ ai_gen_id }}" data-modal-form>
              <input type="text" class="ai-journey-modal__input-{{ ai_gen_id }}" data-comment-author placeholder="Your name" required>
              <input type="text" class="ai-journey-modal__input-{{ ai_gen_id }}" data-comment-text placeholder="Write a comment" required>
              <button type="submit" class="ai-journey-modal__submit-{{ ai_gen_id }}">Post</button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <section class="ai-journey-create-{{ ai_gen_id }}">
      <h3 class="ai-journey-create__title-{{ ai_gen_id }}">Add New Blog</h3>
      <p class="ai-journey-create__subtitle-{{ ai_gen_id }}">Upload image, add title, and write a short description.</p>

      <form class="ai-journey-create__form-{{ ai_gen_id }}" data-create-form>
        <div class="ai-journey-create__group-{{ ai_gen_id }}">
          <label class="ai-journey-create__label-{{ ai_gen_id }}" for="blog-image-{{ ai_gen_id }}">Upload Image</label>
          <input id="blog-image-{{ ai_gen_id }}" class="ai-journey-create__input-file-{{ ai_gen_id }}" type="file" accept="image/*" data-create-image>
        </div>

        <div class="ai-journey-create__group-{{ ai_gen_id }}">
          <label class="ai-journey-create__label-{{ ai_gen_id }}" for="blog-title-{{ ai_gen_id }}">Title</label>
          <input id="blog-title-{{ ai_gen_id }}" class="ai-journey-create__input-{{ ai_gen_id }}" type="text" placeholder="Enter title" data-create-title required>
        </div>

        <div class="ai-journey-create__group-{{ ai_gen_id }}">
          <label class="ai-journey-create__label-{{ ai_gen_id }}" for="blog-description-{{ ai_gen_id }}">Description</label>
          <textarea id="blog-description-{{ ai_gen_id }}" class="ai-journey-create__textarea-{{ ai_gen_id }}" placeholder="Enter description" data-create-description required></textarea>
        </div>

        <button type="submit" class="ai-journey-create__submit-{{ ai_gen_id }}">Add Blog</button>
      </form>
      <p class="ai-journey-create__status-{{ ai_gen_id }}" data-create-status></p>
    </section>

    <script type="application/json" data-posts-json>{{ posts_array | json }}</script>
  </div>
</journey-posts-{{ ai_gen_id }}>

<script>
  (function() {
    class JourneyPosts{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.posts = [];
        this.defaultPosts = [];
        this.activePostIndex = null;
        this.storageKey = 'journey-posts-v2-{{ ai_gen_id }}';
      }

      connectedCallback() {
        this.cacheElements();
        this.loadPosts();
        this.restoreState();
        this.bindEvents();
        this.renderCards();
      }

      cacheElements() {
        this.grid = this.querySelector('[data-posts-grid]');
        this.modal = this.querySelector('[data-post-modal]');
        this.modalMedia = this.querySelector('[data-modal-media]');
        this.modalAuthor = this.querySelector('[data-modal-author]');
        this.modalDate = this.querySelector('[data-modal-date]');
        this.modalTitle = this.querySelector('[data-modal-title]');
        this.modalDescription = this.querySelector('[data-modal-description]');
        this.modalDetail = this.querySelector('[data-modal-detail]');
        this.modalLikeBtn = this.querySelector('[data-modal-like-btn]');
        this.modalLikeCount = this.querySelector('[data-modal-like-count]');
        this.modalCommentCount = this.querySelector('[data-modal-comment-count]');
        this.modalComments = this.querySelector('[data-modal-comments]');
        this.modalEmpty = this.querySelector('[data-modal-empty]');
        this.modalForm = this.querySelector('[data-modal-form]');
        this.modalCommentAuthor = this.querySelector('[data-comment-author]');
        this.modalCommentText = this.querySelector('[data-comment-text]');
        this.createForm = this.querySelector('[data-create-form]');
        this.createImageInput = this.querySelector('[data-create-image]');
        this.createTitleInput = this.querySelector('[data-create-title]');
        this.createDescriptionInput = this.querySelector('[data-create-description]');
        this.createStatus = this.querySelector('[data-create-status]');
      }

      loadPosts() {
        const jsonEl = this.querySelector('[data-posts-json]');
        if (!jsonEl) return;

        try {
          const parsed = JSON.parse(jsonEl.textContent);
          this.defaultPosts = Array.isArray(parsed) ? parsed : [];
          this.posts = this.defaultPosts;
        } catch (error) {
          this.defaultPosts = [];
          this.posts = [];
        }
      }

      restoreState() {
        try {
          const stored = localStorage.getItem(this.storageKey);
          if (!stored) return;

          const parsed = JSON.parse(stored);
          if (!Array.isArray(parsed)) return;
          this.posts = parsed;
        } catch (error) {
          localStorage.removeItem(this.storageKey);
        }
      }

      saveState() {
        try {
          localStorage.setItem(this.storageKey, JSON.stringify(this.posts));
        } catch (error) {
          // Ignore storage failures.
        }
      }

      bindEvents() {
        if (this.grid) {
          this.grid.addEventListener('click', (event) => {
            const likeBtn = event.target.closest('[data-like-btn]');
            const card = event.target.closest('[data-post-card]');
            if (!card) return;

            const index = Number(card.dataset.postIndex);
            if (Number.isNaN(index)) return;

            if (likeBtn) {
              this.toggleLike(index);
              return;
            }

            this.openModal(index);
          });

          this.grid.addEventListener('keydown', (event) => {
            const card = event.target.closest('[data-post-card]');
            if (!card) return;
            if (event.key === 'Enter' || event.key === ' ') {
              event.preventDefault();
              const index = Number(card.dataset.postIndex);
              if (!Number.isNaN(index)) {
                this.openModal(index);
              }
            }
          });
        }

        if (this.createForm) {
          this.createForm.addEventListener('submit', (event) => {
            event.preventDefault();
            this.handleCreatePost();
          });
        }

        const closeBtn = this.querySelector('[data-modal-close]');
        if (closeBtn) {
          closeBtn.addEventListener('click', () => this.closeModal());
        }

        if (this.modal) {
          this.modal.addEventListener('click', (event) => {
            if (event.target === this.modal) {
              this.closeModal();
            }
          });
        }

        this.modalLikeBtn.addEventListener('click', () => {
          if (this.activePostIndex === null) return;
          this.toggleLike(this.activePostIndex);
        });

        this.modalForm.addEventListener('submit', (event) => {
          event.preventDefault();
          this.addComment();
        });

        this.onEscape = (event) => {
          if (event.key === 'Escape') {
            this.closeModal();
          }
        };
      }

      escapeHtml(value) {
        return String(value || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      fallbackImage(index) {
        return 'https://picsum.photos/seed/ro-blog-fallback-' + (index + 1) + '/900/900';
      }

      renderCards() {
        if (!this.grid) return;

        this.grid.innerHTML = this.posts.map((post, index) => {
          const title = this.escapeHtml(post.title);
          const author = this.escapeHtml(post.author || 'Community Member');
          const initials = this.escapeHtml(post.initials || 'CM');
          const date = this.escapeHtml(post.date || '');
          const description = this.escapeHtml(post.description || '');
          const imageUrl = this.escapeHtml(post.image_url || this.fallbackImage(index));
          const isLiked = Boolean(post.isLiked);
          const likes = Number(post.likes || 0);
          const commentsCount = Array.isArray(post.comments) ? post.comments.length : 0;

          return `
            <article class="ai-journey-post-{{ ai_gen_id }}" data-post-card data-post-index="${index}" tabindex="0" role="button" aria-label="Open blog details for ${title}">
              <div class="ai-journey-post__header-{{ ai_gen_id }}">
                <div class="ai-journey-post__avatar-{{ ai_gen_id }}">${initials}</div>
                <div class="ai-journey-post__author-wrap-{{ ai_gen_id }}">
                  <p class="ai-journey-post__author-{{ ai_gen_id }}">${author}</p>
                  <p class="ai-journey-post__date-{{ ai_gen_id }}">${date}</p>
                </div>
              </div>
              <div class="ai-journey-post__image-{{ ai_gen_id }}" data-card-media>
                <img src="${imageUrl}" alt="${title}" loading="lazy">
              </div>
              <div class="ai-journey-post__body-{{ ai_gen_id }}">
                <div class="ai-journey-post__actions-{{ ai_gen_id }}">
                  <div class="ai-journey-post__action-list-{{ ai_gen_id }}">
                    <button type="button" class="ai-journey-post__action-btn-{{ ai_gen_id }} ${isLiked ? 'liked' : ''}" data-like-btn aria-label="Like ${title}" aria-pressed="${isLiked}">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                      </svg>
                      <span data-like-count>${likes}</span>
                    </button>
                    <span class="ai-journey-post__action-btn-{{ ai_gen_id }}" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                      </svg>
                      <span data-comment-count>${commentsCount}</span>
                    </span>
                  </div>
                </div>
                <h3 class="ai-journey-post__title-{{ ai_gen_id }}">${title}</h3>
                <p class="ai-journey-post__caption-{{ ai_gen_id }}">${description}</p>
                <span class="ai-journey-post__open-hint-{{ ai_gen_id }}">Tap to view full story</span>
              </div>
            </article>
          `;
        });
      }

      toggleLike(index) {
        const post = this.posts[index];
        if (!post) return;

        post.isLiked = !post.isLiked;
        post.likes = post.isLiked ? Number(post.likes || 0) + 1 : Math.max(0, Number(post.likes || 0) - 1);

        this.renderCards();
        if (this.activePostIndex === index) {
          this.renderModal(index);
        }

        this.saveState();
      }

      openModal(index) {
        const post = this.posts[index];
        if (!post) return;

        this.activePostIndex = index;
        this.renderModal(index);
        this.modal.classList.add('active');
        this.modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        document.addEventListener('keydown', this.onEscape);
      }

      closeModal() {
        this.modal.classList.remove('active');
        this.modal.setAttribute('aria-hidden', 'true');
        this.activePostIndex = null;
        document.body.style.overflow = '';
        document.removeEventListener('keydown', this.onEscape);
      }

      renderModal(index) {
        const post = this.posts[index];
        if (!post) return;

        const imageUrl = this.escapeHtml(post.image_url || this.fallbackImage(index));
        const title = this.escapeHtml(post.title || 'Blog post');
        this.modalMedia.innerHTML = '<img src="' + imageUrl + '" alt="' + title + '">';
        this.modalAuthor.textContent = post.author || 'Community Member';
        this.modalDate.textContent = post.date || '';
        this.modalTitle.textContent = post.title || '';
        this.modalDescription.textContent = post.description || '';
        this.modalDetail.textContent = post.detail || post.description || '';
        this.modalLikeCount.textContent = Number(post.likes || 0);
        this.modalCommentCount.textContent = Array.isArray(post.comments) ? post.comments.length : 0;

        if (post.isLiked) {
          this.modalLikeBtn.classList.add('liked');
          this.modalLikeBtn.setAttribute('aria-pressed', 'true');
        } else {
          this.modalLikeBtn.classList.remove('liked');
          this.modalLikeBtn.setAttribute('aria-pressed', 'false');
        }

        this.renderModalComments(Array.isArray(post.comments) ? post.comments : []);
      }

      renderModalComments(comments) {
        this.modalComments.innerHTML = '';

        if (!comments.length) {
          this.modalEmpty.style.display = 'block';
          return;
        }

        this.modalEmpty.style.display = 'none';

        comments.forEach((comment) => {
          const wrapper = document.createElement('article');
          wrapper.className = 'ai-journey-modal__comment-{{ ai_gen_id }}';

          const head = document.createElement('div');
          head.className = 'ai-journey-modal__comment-head-{{ ai_gen_id }}';

          const name = document.createElement('span');
          name.className = 'ai-journey-modal__comment-name-{{ ai_gen_id }}';
          name.textContent = comment.author || 'Guest';

          const date = document.createElement('span');
          date.textContent = comment.date || '';

          head.appendChild(name);
          head.appendChild(date);

          const text = document.createElement('p');
          text.className = 'ai-journey-modal__comment-text-{{ ai_gen_id }}';
          text.textContent = comment.text || '';

          wrapper.appendChild(head);
          wrapper.appendChild(text);
          this.modalComments.appendChild(wrapper);
        });
      }

      addComment() {
        if (this.activePostIndex === null) return;

        const post = this.posts[this.activePostIndex];
        const author = this.modalCommentAuthor.value.trim();
        const text = this.modalCommentText.value.trim();

        if (!author || !text || !post) return;

        if (!Array.isArray(post.comments)) {
          post.comments = [];
        }

        post.comments.push({
          author: author,
          text: text,
          date: new Date().toLocaleDateString(undefined, { month: 'short', day: 'numeric' })
        });

        this.modalCommentText.value = '';
        this.renderCards();
        this.renderModal(this.activePostIndex);
        this.saveState();
      }

      async handleCreatePost() {
        const title = this.createTitleInput.value.trim();
        const description = this.createDescriptionInput.value.trim();
        const file = this.createImageInput.files && this.createImageInput.files[0] ? this.createImageInput.files[0] : null;

        if (!title || !description) {
          if (this.createStatus) {
            this.createStatus.textContent = 'Please enter title and description.';
          }
          return;
        }

        let imageUrl = '';
        if (file) {
          try {
            imageUrl = await this.fileToDataUrl(file);
          } catch (error) {
            imageUrl = '';
          }
        }
        if (!imageUrl) {
          imageUrl = this.fallbackImage(this.posts.length + 10);
        }

        const words = title.split(' ').filter(Boolean);
        const initials = ((words[0] ? words[0][0] : 'N') + (words[1] ? words[1][0] : 'B')).toUpperCase();

        this.posts.unshift({
          author: 'Community Member',
          initials: initials,
          date: new Date().toLocaleDateString(undefined, { month: 'long', day: 'numeric', year: 'numeric' }),
          title: title,
          description: description,
          detail: description,
          image_url: imageUrl,
          likes: 0,
          isLiked: false,
          comments: []
        });

        this.renderCards();
        this.saveState();
        this.createForm.reset();
        if (this.createStatus) {
          this.createStatus.textContent = 'Blog added successfully.';
        }
      }

      fileToDataUrl(file) {
        return new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => resolve(reader.result);
          reader.onerror = () => reject(new Error('Failed to read file'));
          reader.readAsDataURL(file);
        });
      }
    }

    if (!customElements.get('journey-posts-{{ ai_gen_id }}')) {
      customElements.define('journey-posts-{{ ai_gen_id }}', JourneyPosts{{ ai_gen_id }});
    }
  })();
</script>

