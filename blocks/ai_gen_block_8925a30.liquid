{% doc %}
  @prompt
    create a sample blog post from the people. this can able to heart and comment to the public. create a sample content for title and description for the journey. blog post should be a sample of atleast 5 sample. with sample image, put a sample image and comment and heart reactions. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-journey-posts-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-journey-posts__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-journey-posts__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-journey-posts__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 10px;
  }

  .ai-journey-posts__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-journey-posts__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
  }

  .ai-journey-post-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_radius }}px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-journey-post-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .ai-journey-post__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 250px;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-journey-post__image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-journey-post__image-wrapper-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-journey-post__content-{{ ai_gen_id }} {
    padding: 20px;
  }

  .ai-journey-post__author-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 15px;
  }

  .ai-journey-post__avatar-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: {{ block.settings.accent_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    font-weight: 600;
    font-size: 16px;
  }

  .ai-journey-post__author-info-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-journey-post__author-name-{{ ai_gen_id }} {
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0;
    font-size: 14px;
  }

  .ai-journey-post__date-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.meta_color }};
    margin: 0;
  }

  .ai-journey-post__title-{{ ai_gen_id }} {
    font-size: 20px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 10px;
  }

  .ai-journey-post__description-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0 0 20px;
  }

  .ai-journey-post__actions-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 20px;
    padding-top: 15px;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }

  .ai-journey-post__action-btn-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px 12px;
    border-radius: 20px;
    transition: background-color 0.2s ease;
    color: {{ block.settings.meta_color }};
    font-size: 14px;
  }

  .ai-journey-post__action-btn-{{ ai_gen_id }}:hover {
    background-color: rgba(0, 0, 0, 0.05);
  }

  .ai-journey-post__action-btn-{{ ai_gen_id }}.liked {
    color: {{ block.settings.accent_color }};
  }

  .ai-journey-post__action-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
  }

  .ai-journey-post__comments-{{ ai_gen_id }} {
    margin-top: 15px;
    padding-top: 15px;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }

  .ai-journey-post__comments-{{ ai_gen_id }}.hidden {
    display: none;
  }

  .ai-journey-post__comment-{{ ai_gen_id }} {
    display: flex;
    gap: 10px;
    margin-bottom: 12px;
  }

  .ai-journey-post__comment-avatar-{{ ai_gen_id }} {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background-color: {{ block.settings.meta_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    font-size: 12px;
    font-weight: 600;
    flex-shrink: 0;
  }

  .ai-journey-post__comment-content-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-journey-post__comment-author-{{ ai_gen_id }} {
    font-weight: 600;
    font-size: 13px;
    color: {{ block.settings.text_color }};
    margin: 0 0 4px;
  }

  .ai-journey-post__comment-text-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-journey-post__comment-form-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
    margin-top: 10px;
  }

  .ai-journey-post__comment-input-{{ ai_gen_id }} {
    flex-grow: 1;
    padding: 8px 12px;
    border: 1px solid rgba(0, 0, 0, 0.2);
    border-radius: 20px;
    font-size: 13px;
    outline: none;
  }

  .ai-journey-post__comment-input-{{ ai_gen_id }}:focus {
    border-color: {{ block.settings.accent_color }};
  }

  .ai-journey-post__comment-submit-{{ ai_gen_id }} {
    padding: 8px 16px;
    background-color: {{ block.settings.accent_color }};
    color: #ffffff;
    border: none;
    border-radius: 20px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    transition: opacity 0.2s ease;
  }

  .ai-journey-post__comment-submit-{{ ai_gen_id }}:hover {
    opacity: 0.9;
  }

  @media screen and (max-width: 768px) {
    .ai-journey-posts__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-journey-post__image-wrapper-{{ ai_gen_id }} {
      height: 200px;
    }
  }
{% endstyle %}

<journey-posts-{{ ai_gen_id }} class="ai-journey-posts-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-journey-posts__container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank %}
      <div class="ai-journey-posts__header-{{ ai_gen_id }}">
        <h2 class="ai-journey-posts__title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
        {% if block.settings.section_subtitle != blank %}
          <p class="ai-journey-posts__subtitle-{{ ai_gen_id }}">{{ block.settings.section_subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-journey-posts__grid-{{ ai_gen_id }}">
      {% assign posts = '
        [
          {
            "author": "Sarah Mitchell",
            "initials": "SM",
            "date": "15 March 2026",
            "title": "Summit Success at Ben Nevis",
            "description": "After months of training, I finally reached the summit of Ben Nevis! The view from the top was absolutely breathtaking. The journey taught me that perseverance pays off.",
            "image": "hero-apparel-1",
            "likes": 127,
            "isLiked": true,
            "comments": [
              {"author": "James", "initials": "J", "text": "Incredible achievement! How long did the climb take?"},
              {"author": "Emma", "initials": "E", "text": "This is so inspiring! Adding this to my bucket list."},
              {"author": "Oliver", "initials": "O", "text": "Well done! The weather looks perfect for it."}
            ]
          },
          {
            "author": "Marcus Chen",
            "initials": "MC",
            "date": "22 March 2026",
            "title": "Coastal Trail Discovery",
            "description": "Explored the stunning coastal trails of Cornwall this weekend. The combination of rugged cliffs and turquoise waters was magical. Perfect weather made it even better!",
            "image": "collection-apparel-1",
            "likes": 89,
            "isLiked": false,
            "comments": [
              {"author": "Lucy", "initials": "L", "text": "Cornwall is beautiful! Which trail did you take?"},
              {"author": "Daniel", "initials": "D", "text": "I love this area! Great photos."}
            ]
          },
          {
            "author": "Olivia Thompson",
            "initials": "OT",
            "date": "25 March 2026",
            "title": "Wild Camping in the Highlands",
            "description": "Spent three nights wild camping in the Scottish Highlands. Waking up to misty mountains and complete silence was a dream. This is what adventure is all about!",
            "image": "detailed-apparel-1",
            "likes": 156,
            "isLiked": true,
            "comments": [
              {"author": "Tom", "initials": "T", "text": "Looks amazing! Any tips for first-time wild campers?"},
              {"author": "Sophie", "initials": "S", "text": "The Highlands are on my list for this summer!"},
              {"author": "Alex", "initials": "A", "text": "Stunning location! What gear did you bring?"}
            ]
          },
          {
            "author": "David Roberts",
            "initials": "DR",
            "date": "27 March 2026",
            "title": "Mountain Biking Adventure",
            "description": "Tackled some challenging mountain bike trails in Wales today. The adrenaline rush going downhill was incredible! Already planning my next ride.",
            "image": "product-apparel-1",
            "likes": 94,
            "isLiked": false,
            "comments": [
              {"author": "Mike", "initials": "M", "text": "Which trails? Looking for new routes to try!"},
              {"author": "Katie", "initials": "K", "text": "This looks intense! Stay safe out there."}
            ]
          },
          {
            "author": "Hannah Wilson",
            "initials": "HW",
            "date": "29 March 2026",
            "title": "Kayaking the Lake District",
            "description": "Spent the day kayaking across Windermere. The water was crystal clear and the surrounding mountains created the perfect backdrop. An unforgettable experience!",
            "image": "blog-apparel-1",
            "likes": 112,
            "isLiked": true,
            "comments": [
              {"author": "Rachel", "initials": "R", "text": "This looks so peaceful! Did you rent or bring your own kayak?"},
              {"author": "Chris", "initials": "C", "text": "The Lake District never disappoints!"},
              {"author": "Megan", "initials": "M", "text": "Beautiful! I need to visit soon."}
            ]
          }
        ]
      ' | strip %}

      {% assign posts_array = posts | parse_json %}

      {% for post in posts_array %}
        <article class="ai-journey-post-{{ ai_gen_id }}" data-post-id="{{ forloop.index }}">
          <div class="ai-journey-post__image-wrapper-{{ ai_gen_id }}">
            {{ post.image | placeholder_svg_tag }}
          </div>

          <div class="ai-journey-post__content-{{ ai_gen_id }}">
            <div class="ai-journey-post__author-{{ ai_gen_id }}">
              <div class="ai-journey-post__avatar-{{ ai_gen_id }}">{{ post.initials }}</div>
              <div class="ai-journey-post__author-info-{{ ai_gen_id }}">
                <p class="ai-journey-post__author-name-{{ ai_gen_id }}">{{ post.author }}</p>
                <p class="ai-journey-post__date-{{ ai_gen_id }}">{{ post.date }}</p>
              </div>
            </div>

            <h3 class="ai-journey-post__title-{{ ai_gen_id }}">{{ post.title }}</h3>
            <p class="ai-journey-post__description-{{ ai_gen_id }}">{{ post.description }}</p>

            <div class="ai-journey-post__actions-{{ ai_gen_id }}">
              <button 
                class="ai-journey-post__action-btn-{{ ai_gen_id }} like-btn {% if post.isLiked %}liked{% endif %}" 
                data-likes="{{ post.likes }}" 
                aria-label="Like this post"
                aria-pressed="{% if post.isLiked %}true{% else %}false{% endif %}"
              >
                <svg class="ai-journey-post__action-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" {% if post.isLiked %}fill="currentColor"{% else %}fill="none"{% endif %} stroke="currentColor" stroke-width="2">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                </svg>
                <span class="like-count">{{ post.likes }}</span>
              </button>

              <button class="ai-journey-post__action-btn-{{ ai_gen_id }} comment-btn" aria-label="View comments" aria-expanded="false">
                <svg class="ai-journey-post__action-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                </svg>
                <span class="comment-count">{{ post.comments.size }}</span>
              </button>
            </div>

            <div class="ai-journey-post__comments-{{ ai_gen_id }} hidden">
              {% for comment in post.comments %}
                <div class="ai-journey-post__comment-{{ ai_gen_id }}">
                  <div class="ai-journey-post__comment-avatar-{{ ai_gen_id }}">{{ comment.initials }}</div>
                  <div class="ai-journey-post__comment-content-{{ ai_gen_id }}">
                    <p class="ai-journey-post__comment-author-{{ ai_gen_id }}">{{ comment.author }}</p>
                    <p class="ai-journey-post__comment-text-{{ ai_gen_id }}">{{ comment.text }}</p>
                  </div>
                </div>
              {% endfor %}

              <div class="ai-journey-post__comment-form-{{ ai_gen_id }}">
                <input 
                  type="text" 
                  class="ai-journey-post__comment-input-{{ ai_gen_id }}" 
                  placeholder="Add a comment..."
                  aria-label="Add a comment"
                >
                <button class="ai-journey-post__comment-submit-{{ ai_gen_id }}" aria-label="Post comment">Post</button>
              </div>
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</journey-posts-{{ ai_gen_id }}>

<script>
  (function() {
    class JourneyPosts{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupLikeButtons();
        this.setupCommentButtons();
        this.setupCommentForms();
      }

      setupLikeButtons() {
        const likeButtons = this.querySelectorAll('.like-btn');
        
        likeButtons.forEach(button => {
          button.addEventListener('click', function() {
            const isLiked = this.classList.contains('liked');
            const likeCountSpan = this.querySelector('.like-count');
            let currentLikes = parseInt(likeCountSpan.textContent);

            if (isLiked) {
              this.classList.remove('liked');
              currentLikes--;
              const heartPath = this.querySelector('svg path');
              heartPath.setAttribute('fill', 'none');
              this.setAttribute('aria-pressed', 'false');
            } else {
              this.classList.add('liked');
              currentLikes++;
              const heartPath = this.querySelector('svg path');
              heartPath.setAttribute('fill', 'currentColor');
              this.setAttribute('aria-pressed', 'true');
            }

            likeCountSpan.textContent = currentLikes;
          });
        });
      }

      setupCommentButtons() {
        const commentButtons = this.querySelectorAll('.comment-btn');
        
        commentButtons.forEach(button => {
          button.addEventListener('click', function() {
            const post = this.closest('.ai-journey-post-{{ ai_gen_id }}');
            const commentsSection = post.querySelector('.ai-journey-post__comments-{{ ai_gen_id }}');
            
            if (commentsSection.classList.contains('hidden')) {
              commentsSection.classList.remove('hidden');
              this.setAttribute('aria-expanded', 'true');
            } else {
              commentsSection.classList.add('hidden');
              this.setAttribute('aria-expanded', 'false');
            }
          });
        });
      }

      setupCommentForms() {
        const commentForms = this.querySelectorAll('.ai-journey-post__comment-form-{{ ai_gen_id }}');
        
        commentForms.forEach(form => {
          const input = form.querySelector('.ai-journey-post__comment-input-{{ ai_gen_id }}');
          const submitBtn = form.querySelector('.ai-journey-post__comment-submit-{{ ai_gen_id }}');
          
          submitBtn.addEventListener('click', function() {
            const commentText = input.value.trim();
            
            if (commentText) {
              const post = form.closest('.ai-journey-post-{{ ai_gen_id }}');
              const commentsContainer = post.querySelector('.ai-journey-post__comments-{{ ai_gen_id }}');
              const commentCountSpan = post.querySelector('.comment-count');
              
              const newComment = document.createElement('div');
              newComment.className = 'ai-journey-post__comment-{{ ai_gen_id }}';
              newComment.innerHTML = `
                <div class="ai-journey-post__comment-avatar-{{ ai_gen_id }}">Y</div>
                <div class="ai-journey-post__comment-content-{{ ai_gen_id }}">
                  <p class="ai-journey-post__comment-author-{{ ai_gen_id }}">You</p>
                  <p class="ai-journey-post__comment-text-{{ ai_gen_id }}">${commentText}</p>
                </div>
              `;
              
              commentsContainer.insertBefore(newComment, form);
              
              let currentCount = parseInt(commentCountSpan.textContent);
              commentCountSpan.textContent = currentCount + 1;
              
              input.value = '';
            }
          });
          
          input.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
              submitBtn.click();
            }
          });
        });
      }
    }

    customElements.define('journey-posts-{{ ai_gen_id }}', JourneyPosts{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Journey blog posts",
  "settings": [
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Title",
      "default": "Community Adventures"
    },
    {
      "type": "text",
      "id": "section_subtitle",
      "label": "Subtitle",
      "default": "Share your journey with fellow adventurers"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 24,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Subtitle size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f9f6ef"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "meta_color",
      "label": "Meta text",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#375937"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Journey blog posts"
    }
  ]
}
{% endschema %}