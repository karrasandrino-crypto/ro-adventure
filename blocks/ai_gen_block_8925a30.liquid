<script>
  (function() {
    class JourneyPosts{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.posts = [];
        this.defaultPosts = [];
        this.readOnlyMode = false;
        this.activePostIndex = null;
        this.pendingLikeIds = new Set();
        this.pendingCommentPostIds = new Set();
        this.isCreatingPost = false;
        this.apiBaseUrl = this.normalizeApiBaseUrl({{ block.settings.api_base_url | default: 'https://ro-adventure-backend-production-5546.up.railway.app/api' | json }});
        this.apiOrigin = this.resolveApiOrigin(this.apiBaseUrl);
      }

      connectedCallback() {
        this.cacheElements();
        this.applyReadOnlyMode();
        this.loadPosts();
        this.bindEvents();
        this.renderCards();
        this.hydrateFromApi();
      }

      applyReadOnlyMode() {
        if (!this.readOnlyMode) return;

        if (this.createForm) this.createForm.style.display = '';
        if (this.modalForm) this.modalForm.style.display = '';
        this.clearCreateStatus();
      }

      cacheElements() {
        this.grid = this.querySelector('[data-posts-grid]');
        this.modal = this.querySelector('[data-post-modal]');
        this.modalMedia = this.querySelector('[data-modal-media]');
        this.modalAuthor = this.querySelector('[data-modal-author]');
        this.modalDate = this.querySelector('[data-modal-date]');
        this.modalTitle = this.querySelector('[data-modal-title]');
        this.modalDescription = this.querySelector('[data-modal-description]');
        this.modalDetail = this.querySelector('[data-modal-detail]');
        this.modalLikeBtn = this.querySelector('[data-modal-like-btn]');
        this.modalLikeCount = this.querySelector('[data-modal-like-count]');
        this.modalCommentCount = this.querySelector('[data-modal-comment-count]');
        this.modalComments = this.querySelector('[data-modal-comments]');
        this.modalEmpty = this.querySelector('[data-modal-empty]');
        this.modalForm = this.querySelector('[data-modal-form]');
        this.modalCommentAuthor = this.querySelector('[data-comment-author]');
        this.modalCommentText = this.querySelector('[data-comment-text]');
        this.createForm = this.querySelector('[data-create-form]');
        this.createImageInput = this.querySelector('[data-create-image]');
        this.createAuthorInput = this.querySelector('[data-create-author]');
        this.createTitleInput = this.querySelector('[data-create-title]');
        this.createDescriptionInput = this.querySelector('[data-create-description]');
        this.createStatus = this.querySelector('[data-create-status]');
        this.modalSubmitBtn = this.modalForm ? this.modalForm.querySelector('button[type="submit"]') : null;
        this.createSubmitBtn = this.createForm ? this.createForm.querySelector('button[type="submit"]') : null;
        this.modalSubmitDefaultLabel = this.modalSubmitBtn ? this.modalSubmitBtn.textContent : 'Post';
        this.createSubmitDefaultLabel = this.createSubmitBtn ? this.createSubmitBtn.textContent : 'Add Blog';
      }

      loadPosts() {
        const jsonEl = this.querySelector('[data-posts-json]');
        if (!jsonEl) return;

        try {
          const parsed = JSON.parse(jsonEl.textContent);
          this.defaultPosts = Array.isArray(parsed) ? parsed : [];
          this.posts = this.defaultPosts.map((post, index) => this.normalizePost(post, index));
        } catch (error) {
          this.defaultPosts = [];
          this.posts = [];
        }
      }

      bindEvents() {
        if (this.grid) {
          this.grid.addEventListener('click', (event) => {
            const likeBtn = event.target.closest('[data-like-btn]');
            const card = event.target.closest('[data-post-card]');
            if (!card) return;

            const index = Number(card.dataset.postIndex);
            if (Number.isNaN(index)) return;

            if (likeBtn) {
              if (!this.readOnlyMode) {
                this.toggleLike(index);
              }
              return;
            }

            this.openModal(index);
          });

          this.grid.addEventListener('keydown', (event) => {
            const card = event.target.closest('[data-post-card]');
            if (!card) return;
            if (event.key === 'Enter' || event.key === ' ') {
              event.preventDefault();
              const index = Number(card.dataset.postIndex);
              if (!Number.isNaN(index)) {
                this.openModal(index);
              }
            }
          });
        }

        if (this.createImageInput) {
          this.createImageInput.addEventListener('change', () => {
            const labelEl = this.querySelector('[data-upload-label]');
            if (labelEl) {
              const file = this.createImageInput.files && this.createImageInput.files[0];
              labelEl.textContent = file ? file.name : 'Choose file';
            }
          });
        }

        if (this.createForm) {
          this.createForm.addEventListener('submit', (event) => {
            event.preventDefault();
            if (this.readOnlyMode) return;
            this.handleCreatePost();
          });
        }

        const closeBtn = this.querySelector('[data-modal-close]');
        if (closeBtn) {
          closeBtn.addEventListener('click', () => this.closeModal());
        }

        if (this.modal) {
          this.modal.addEventListener('click', (event) => {
            if (event.target === this.modal) {
              this.closeModal();
            }
          });
        }

        if (this.modalLikeBtn) {
          this.modalLikeBtn.addEventListener('click', () => {
            if (this.activePostIndex === null) return;
            if (this.readOnlyMode) return;
            this.toggleLike(this.activePostIndex);
          });
        }

        if (this.modalForm) {
          this.modalForm.addEventListener('submit', (event) => {
            event.preventDefault();
            if (this.readOnlyMode) return;
            this.addComment();
          });
        }

        this.onEscape = (event) => {
          if (event.key === 'Escape') {
            this.closeModal();
          }
        };
      }

      normalizeApiBaseUrl(value) {
        const fallback = 'https://ro-adventure-backend-production-5546.up.railway.app/api';
        const raw = typeof value === 'string' && value.trim() ? value.trim() : fallback;
        const withProtocol = /^https?:\/\//i.test(raw) ? raw : 'https://' + raw;
        try {
          const parsed = new URL(withProtocol);
          if (parsed.protocol !== 'http:' && parsed.protocol !== 'https:') {
            return fallback;
          }

          const path = parsed.pathname.replace(/\/+$/, '');
          parsed.pathname = path && path !== '/' ? path : '/api';
          return parsed.toString().replace(/\/+$/, '');
        } catch (error) {
          return fallback;
        }
      }

      resolveApiOrigin(value) {
        try {
          return new URL(value).origin;
        } catch (error) {
          return window.location.origin;
        }
      }

      buildApiUrl(path) {
        const normalizedPath = path.startsWith('/') ? path : '/' + path;
        return this.apiBaseUrl + normalizedPath;
      }

      async apiRequest(path, options) {
        const controller = new AbortController();
        const timeoutId = window.setTimeout(() => controller.abort(), 15000);
        let response;

        try {
          response = await fetch(this.buildApiUrl(path), Object.assign({}, options || {}, {
            signal: controller.signal
          }));
        } catch (error) {
          if (error && error.name === 'AbortError') {
            throw new Error('Request timed out. Please try again.');
          }
          throw new Error('Network request failed. Please try again.');
        } finally {
          window.clearTimeout(timeoutId);
        }

        let payload = null;

        try {
          payload = await response.json();
        } catch (error) {
          payload = null;
        }

        if (!response.ok || (payload && payload.ok === false)) {
          const message = payload && payload.message ? payload.message : 'Request failed';
          throw new Error(message);
        }

        return payload || {};
      }

      async hydrateFromApi() {
        try {
          const payload = await this.apiRequest('/posts');
          const apiPosts = Array.isArray(payload.posts) ? payload.posts : [];
          this.posts = apiPosts.map((post, index) => this.normalizePost(post, index));
          this.renderCards();
          this.clearCreateStatus();
        } catch (error) {
          this.setCreateStatus('Showing sample posts. API is currently unreachable.', true);
        }
      }

      setCreateStatus(message, isError) {
        if (!this.createStatus) return;
        this.createStatus.textContent = message || '';
        this.createStatus.style.color = isError ? '#b42318' : '';
      }

      setCreateSubmitting(isBusy) {
        this.isCreatingPost = Boolean(isBusy);
        if (!this.createSubmitBtn) return;
        this.createSubmitBtn.disabled = this.isCreatingPost;
        this.createSubmitBtn.textContent = this.isCreatingPost ? 'Publishing...' : this.createSubmitDefaultLabel;
      }

      setCommentSubmitting(isBusy) {
        const busy = Boolean(isBusy);
        if (this.modalSubmitBtn) {
          this.modalSubmitBtn.disabled = busy;
          this.modalSubmitBtn.textContent = busy ? 'Posting...' : this.modalSubmitDefaultLabel;
        }
        if (this.modalCommentAuthor) {
          this.modalCommentAuthor.disabled = busy;
        }
        if (this.modalCommentText) {
          this.modalCommentText.disabled = busy;
        }
      }

      clearCreateStatus() {
        if (!this.createStatus) return;
        this.createStatus.textContent = '';
        this.createStatus.style.color = '';
      }

      limitText(value, maxLength) {
        return String(value || '').trim().slice(0, maxLength);
      }

      getPostId(post) {
        const parsed = Number(post && post.id);
        return Number.isFinite(parsed) && parsed > 0 ? parsed : null;
      }

      getInitials(value) {
        const words = String(value || '')
          .split(' ')
          .map((item) => item.trim())
          .filter(Boolean);
        const first = words[0] ? words[0][0] : 'C';
        const second = words[1] ? words[1][0] : 'M';
        return (first + second).toUpperCase();
      }

      resolveImageUrl(value, index) {
        const raw = String(value || '').trim();
        if (!raw) {
          return this.fallbackImage(index);
        }

        if (/^https?:\/\//i.test(raw)) {
          try {
            const parsed = new URL(raw);
            if (parsed.protocol === 'http:' || parsed.protocol === 'https:') {
              return parsed.toString();
            }
          } catch (error) {
            return this.fallbackImage(index);
          }
        }

        if (raw.startsWith('/uploads/')) {
          return this.apiOrigin + raw;
        }

        return this.fallbackImage(index);
      }

      normalizeComment(comment, index) {
        const source = comment && typeof comment === 'object' ? comment : {};
        return {
          id: Number.isFinite(Number(source.id)) ? Number(source.id) : index + 1,
          author: source.author || 'Guest',
          text: source.text || '',
          date: source.date || ''
        };
      }

      normalizePost(post, index) {
        const source = post && typeof post === 'object' ? post : {};
        const author = source.author || 'Community Member';
        const comments = Array.isArray(source.comments)
          ? source.comments.map((comment, commentIndex) => this.normalizeComment(comment, commentIndex))
          : [];

        return {
          id: Number.isFinite(Number(source.id)) ? Number(source.id) : null,
          author: author,
          initials: source.initials || this.getInitials(author),
          date: source.date || '',
          title: source.title || '',
          description: source.description || '',
          detail: source.detail || source.description || '',
          image_url: this.resolveImageUrl(source.image_url, index),
          likes: Math.max(0, Number(source.likes) || 0),
          isLiked: Boolean(source.isLiked),
          comments: comments
        };
      }

      escapeHtml(value) {
        return String(value || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      fallbackImage(index) {
        return 'https://picsum.photos/seed/ro-blog-fallback-' + (index + 1) + '/900/900';
      }

      renderCards() {
        if (!this.grid) return;

        this.grid.innerHTML = this.posts.map((post, index) => {
          const title = this.escapeHtml(post.title);
          const author = this.escapeHtml(post.author || 'Community Member');
          const initials = this.escapeHtml(post.initials || 'CM');
          const date = this.escapeHtml(post.date || '');
          const description = this.escapeHtml(post.description || '');
          const imageUrl = this.escapeHtml(post.image_url || this.fallbackImage(index));
          const isLiked = Boolean(post.isLiked);
          const likes = Number(post.likes || 0);
          const commentsCount = Array.isArray(post.comments) ? post.comments.length : 0;
          const postId = this.getPostId(post);
          const isLikePending = Boolean(postId && this.pendingLikeIds.has(postId));
          const isLikeDisabled = this.readOnlyMode || isLikePending;

          return `
            <div class="ai-journey-post-{{ ai_gen_id }}" data-post-card data-post-index="${index}" tabindex="0" role="button" aria-label="Open blog details for ${title}">
              <div class="ai-journey-post__header-{{ ai_gen_id }}">
                <div class="ai-journey-post__avatar-{{ ai_gen_id }}">${initials}</div>
                <div class="ai-journey-post__author-wrap-{{ ai_gen_id }}">
                  <p class="ai-journey-post__author-{{ ai_gen_id }}">${author}</p>
                  <p class="ai-journey-post__date-{{ ai_gen_id }}">${date}</p>
                </div>
              </div>
              <div class="ai-journey-post__image-{{ ai_gen_id }}" data-card-media>
                <img src="${imageUrl}" alt="${title}" loading="lazy">
              </div>
              <div class="ai-journey-post__body-{{ ai_gen_id }}">
                <div class="ai-journey-post__actions-{{ ai_gen_id }}">
                  <div class="ai-journey-post__action-list-{{ ai_gen_id }}">
                    <button type="button" class="ai-journey-post__action-btn-{{ ai_gen_id }} ${isLiked ? 'liked' : ''}" data-like-btn aria-label="Like ${title}" aria-pressed="${isLiked}" ${isLikeDisabled ? 'disabled' : ''} ${isLikePending ? 'aria-busy="true"' : ''}>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                      </svg>
                      <span data-like-count>${likes}</span>
                    </button>
                    <span class="ai-journey-post__action-btn-{{ ai_gen_id }}" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                      </svg>
                      <span data-comment-count>${commentsCount}</span>
                    </span>
                  </div>
                </div>
                <h3 class="ai-journey-post__title-{{ ai_gen_id }}">${title}</h3>
                <p class="ai-journey-post__caption-{{ ai_gen_id }}">${description}</p>
                <span class="ai-journey-post__open-hint-{{ ai_gen_id }}">Tap to view full story</span>
              </div>
            </div>
          `;
        }).join('');
      }

      async toggleLike(index) {
        if (this.readOnlyMode) return;
        const post = this.posts[index];
        if (!post) return;
        const postId = this.getPostId(post);
        if (postId && this.pendingLikeIds.has(postId)) return;

        const previousLiked = Boolean(post.isLiked);
        const previousLikes = Math.max(0, Number(post.likes) || 0);
        const nextLiked = !previousLiked;
        if (postId) {
          this.pendingLikeIds.add(postId);
        }

        post.isLiked = nextLiked;
        post.likes = nextLiked ? previousLikes + 1 : Math.max(0, previousLikes - 1);

        this.renderCards();
        if (this.activePostIndex === index) {
          this.renderModal(index);
        }

        if (!postId) return;

        try {
          const payload = await this.apiRequest('/posts/' + postId + '/like', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({ liked: nextLiked })
          });

          post.likes = Math.max(0, Number(payload.likes) || 0);
          post.isLiked = nextLiked;
          this.renderCards();
          if (this.activePostIndex === index) {
            this.renderModal(index);
          }
          this.clearCreateStatus();
        } catch (error) {
          post.isLiked = previousLiked;
          post.likes = previousLikes;
          this.renderCards();
          if (this.activePostIndex === index) {
            this.renderModal(index);
          }
          this.setCreateStatus(error.message || 'Unable to update like.', true);
        } finally {
          if (postId) {
            this.pendingLikeIds.delete(postId);
            this.renderCards();
            if (this.activePostIndex === index) {
              this.renderModal(index);
            }
          }
        }
      }

      openModal(index) {
        const post = this.posts[index];
        if (!post) return;

        this.activePostIndex = index;
        this.renderModal(index);
        this.modal.classList.add('active');
        this.modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        document.addEventListener('keydown', this.onEscape);
      }

      closeModal() {
        this.modal.classList.remove('active');
        this.modal.setAttribute('aria-hidden', 'true');
        this.activePostIndex = null;
        document.body.style.overflow = '';
        document.removeEventListener('keydown', this.onEscape);
      }

      renderModal(index) {
        const post = this.posts[index];
        if (!post) return;

        const imageUrl = this.escapeHtml(post.image_url || this.fallbackImage(index));
        const title = this.escapeHtml(post.title || 'Blog post');
        this.modalMedia.innerHTML = '<img src="' + imageUrl + '" alt="' + title + '">';
        this.modalAuthor.textContent = post.author || 'Community Member';
        this.modalDate.textContent = post.date || '';
        this.modalTitle.textContent = post.title || '';
        this.modalDescription.textContent = post.description || '';
        this.modalDetail.textContent = post.detail || post.description || '';
        this.modalLikeCount.textContent = Number(post.likes || 0);
        this.modalCommentCount.textContent = Array.isArray(post.comments) ? post.comments.length : 0;
        const postId = this.getPostId(post);
        const isLikePending = Boolean(postId && this.pendingLikeIds.has(postId));
        const isCommentPending = Boolean(postId && this.pendingCommentPostIds.has(postId));

        if (post.isLiked) {
          this.modalLikeBtn.classList.add('liked');
          this.modalLikeBtn.setAttribute('aria-pressed', 'true');
        } else {
          this.modalLikeBtn.classList.remove('liked');
          this.modalLikeBtn.setAttribute('aria-pressed', 'false');
        }
        this.modalLikeBtn.disabled = this.readOnlyMode || isLikePending;
        if (isLikePending) {
          this.modalLikeBtn.setAttribute('aria-busy', 'true');
        } else {
          this.modalLikeBtn.removeAttribute('aria-busy');
        }
        this.setCommentSubmitting(this.readOnlyMode || isCommentPending);

        this.renderModalComments(Array.isArray(post.comments) ? post.comments : []);
      }

      renderModalComments(comments) {
        this.modalComments.innerHTML = '';

        if (!comments.length) {
          this.modalEmpty.style.display = 'block';
          return;
        }

        this.modalEmpty.style.display = 'none';

        comments.forEach((comment) => {
          const wrapper = document.createElement('article');
          wrapper.className = 'ai-journey-modal__comment-{{ ai_gen_id }}';

          const head = document.createElement('div');
          head.className = 'ai-journey-modal__comment-head-{{ ai_gen_id }}';

          const name = document.createElement('span');
          name.className = 'ai-journey-modal__comment-name-{{ ai_gen_id }}';
          name.textContent = comment.author || 'Guest';

          const date = document.createElement('span');
          date.textContent = comment.date || '';

          head.appendChild(name);
          head.appendChild(date);

          const text = document.createElement('p');
          text.className = 'ai-journey-modal__comment-text-{{ ai_gen_id }}';
          text.textContent = comment.text || '';

          wrapper.appendChild(head);
          wrapper.appendChild(text);
          this.modalComments.appendChild(wrapper);
        });
      }

      async addComment() {
        if (this.readOnlyMode) return;
        if (this.activePostIndex === null) return;

        const post = this.posts[this.activePostIndex];
        const author = this.limitText(this.modalCommentAuthor.value, 80);
        const text = this.limitText(this.modalCommentText.value, 500);
        const postId = this.getPostId(post);

        if (!author || !text || !post) return;
        if (postId && this.pendingCommentPostIds.has(postId)) return;

        if (!Array.isArray(post.comments)) {
          post.comments = [];
        }

        if (postId) {
          this.pendingCommentPostIds.add(postId);
          this.renderModal(this.activePostIndex);
          try {
            const payload = await this.apiRequest('/posts/' + postId + '/comments', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({
                author: author,
                text: text
              })
            });

            post.comments.push(this.normalizeComment(payload.comment || {}, post.comments.length));
            this.clearCreateStatus();
          } catch (error) {
            this.setCreateStatus(error.message || 'Unable to add comment.', true);
            return;
          } finally {
            this.pendingCommentPostIds.delete(postId);
            if (this.activePostIndex !== null) {
              this.renderModal(this.activePostIndex);
            }
          }
        } else {
          post.comments.push({
            id: post.comments.length + 1,
            author: author,
            text: text,
            date: new Date().toLocaleDateString(undefined, { month: 'short', day: 'numeric' })
          });
        }

        this.modalCommentText.value = '';
        this.renderCards();
        this.renderModal(this.activePostIndex);
      }

      async handleCreatePost() {
        if (this.readOnlyMode) return;
        if (this.isCreatingPost) return;

        const author = this.createAuthorInput ? this.limitText(this.createAuthorInput.value, 80) : '';
        const title = this.limitText(this.createTitleInput.value, 120);
        const description = this.limitText(this.createDescriptionInput.value, 500);
        const file = this.createImageInput.files && this.createImageInput.files[0] ? this.createImageInput.files[0] : null;

        if (!title || !description) {
          this.setCreateStatus('Please fill in title and description.', true);
          return;
        }

        const formData = new FormData();
        formData.append('author', author || 'Community Member');
        formData.append('title', title);
        formData.append('description', description);
        formData.append('detail', description);
        if (file) {
          formData.append('image', file);
        }

        this.setCreateSubmitting(true);
        this.setCreateStatus('Publishing post...', false);

        try {
          const payload = await this.apiRequest('/posts', {
            method: 'POST',
            body: formData
          });

          if (payload.post) {
            this.posts.unshift(this.normalizePost(payload.post, this.posts.length));
            this.renderCards();
          } else {
            await this.hydrateFromApi();
          }

          this.createForm.reset();
          const uploadLabelEl = this.querySelector('[data-upload-label]');
          if (uploadLabelEl) uploadLabelEl.textContent = 'Choose file';
          this.setCreateStatus('Blog added successfully.', false);
        } catch (error) {
          this.setCreateStatus(error.message || 'Unable to publish blog.', true);
        } finally {
          this.setCreateSubmitting(false);
        }
      }
    }

    if (!customElements.get('journey-posts-{{ ai_gen_id }}')) {
      customElements.define('journey-posts-{{ ai_gen_id }}', JourneyPosts{{ ai_gen_id }});
    }
  })();
</script>

