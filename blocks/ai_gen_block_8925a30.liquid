{% doc %}
  @prompt
    create a sample blog post from the people. this can able to heart and comment to the public. create a sample content for title and description for the journey. blog post should be a sample of atleast 5 sample. with sample image, put a sample image and comment and heart reactions.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-journey-posts-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 28px 20px 52px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-journey-posts__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-journey-posts__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 30px;
  }

  .ai-journey-posts__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 10px;
    line-height: 1.15;
  }

  .ai-journey-posts__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-journey-posts__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-auto-flow: row;
    align-items: start;
    gap: 22px;
  }

  .ai-journey-posts__grid-{{ ai_gen_id }} > .ai-journey-post-{{ ai_gen_id }} {
    width: 100% !important;
    max-width: none !important;
    margin: 0 !important;
    justify-self: stretch;
    align-self: start;
  }

  .ai-journey-post-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_radius }}px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    display: flex;
    flex-direction: column;
  }

  .ai-journey-post-{{ ai_gen_id }}:hover,
  .ai-journey-post-{{ ai_gen_id }}:focus-visible {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.14);
  }

  .ai-journey-post__header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
  }

  .ai-journey-post__avatar-{{ ai_gen_id }} {
    width: 34px;
    height: 34px;
    border-radius: 999px;
    background-color: {{ block.settings.accent_color }};
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .ai-journey-post__author-wrap-{{ ai_gen_id }} {
    min-width: 0;
  }

  .ai-journey-post__author-{{ ai_gen_id }} {
    margin: 0;
    font-size: 13px;
    color: {{ block.settings.text_color }};
    font-weight: 700;
    line-height: 1.2;
  }

  .ai-journey-post__date-{{ ai_gen_id }} {
    margin: 0;
    font-size: 12px;
    color: {{ block.settings.meta_color }};
    line-height: 1.2;
  }

  .ai-journey-post__image-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #e9ece8;
  }

  .ai-journey-post__image-{{ ai_gen_id }} img,
  .ai-journey-post__image-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .ai-journey-post__body-{{ ai_gen_id }} {
    padding: 12px 14px 14px;
  }

  .ai-journey-post__actions-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .ai-journey-post__action-list-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .ai-journey-post__action-btn-{{ ai_gen_id }} {
    border: 0;
    background: transparent;
    padding: 0;
    margin: 0;
    display: inline-flex;
    gap: 6px;
    align-items: center;
    color: {{ block.settings.meta_color }};
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
  }

  .ai-journey-post__action-btn-{{ ai_gen_id }} svg {
    width: 18px;
    height: 18px;
  }

  .ai-journey-post__action-btn-{{ ai_gen_id }}.liked {
    color: {{ block.settings.accent_color }};
  }

  .ai-journey-post__title-{{ ai_gen_id }} {
    margin: 0 0 6px;
    font-size: 15px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    line-height: 1.35;
  }

  .ai-journey-post__caption-{{ ai_gen_id }} {
    margin: 0;
    font-size: 13px;
    color: {{ block.settings.text_color }};
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-journey-post__open-hint-{{ ai_gen_id }} {
    display: inline-flex;
    margin-top: 10px;
    font-size: 12px;
    color: {{ block.settings.meta_color }};
  }

  .ai-journey-modal-{{ ai_gen_id }} {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: none;
    background: rgba(18, 18, 18, 0.78);
    padding: 20px;
    align-items: center;
    justify-content: center;
  }

  .ai-journey-modal-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-journey-modal__panel-{{ ai_gen_id }} {
    width: min(1100px, 100%);
    max-height: calc(100vh - 40px);
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_radius }}px;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
  }

  .ai-journey-modal__media-{{ ai_gen_id }} {
    background: #f2f3ef;
    min-height: 360px;
  }

  .ai-journey-modal__media-{{ ai_gen_id }} img,
  .ai-journey-modal__media-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-journey-modal__content-{{ ai_gen_id }} {
    padding: 20px;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .ai-journey-modal__top-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
    gap: 10px;
  }

  .ai-journey-modal__meta-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    color: {{ block.settings.meta_color }};
    font-size: 13px;
  }

  .ai-journey-modal__close-{{ ai_gen_id }} {
    border: 0;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    background: #f2f2f2;
    color: {{ block.settings.text_color }};
    font-size: 20px;
    cursor: pointer;
  }

  .ai-journey-modal__title-{{ ai_gen_id }} {
    margin: 0 0 8px;
    font-size: 24px;
    line-height: 1.25;
    color: {{ block.settings.text_color }};
  }

  .ai-journey-modal__description-{{ ai_gen_id }} {
    margin: 0 0 14px;
    color: {{ block.settings.text_color }};
    font-size: 14px;
    line-height: 1.6;
  }

  .ai-journey-modal__actions-{{ ai_gen_id }} {
    padding: 10px 0 12px;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    margin-bottom: 12px;
    display: flex;
    gap: 14px;
  }

  .ai-journey-modal__scroll-{{ ai_gen_id }} {
    overflow: auto;
    padding-right: 2px;
  }

  .ai-journey-modal__detail-{{ ai_gen_id }} {
    margin: 0 0 14px;
    color: {{ block.settings.text_color }};
    font-size: 14px;
    line-height: 1.65;
  }

  .ai-journey-modal__comments-title-{{ ai_gen_id }} {
    margin: 0 0 10px;
    font-size: 15px;
    color: {{ block.settings.text_color }};
  }

  .ai-journey-modal__comment-list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 12px;
  }

  .ai-journey-modal__comment-{{ ai_gen_id }} {
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 10px;
    padding: 10px;
    background: #ffffff;
  }

  .ai-journey-modal__comment-head-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 6px;
    font-size: 12px;
    color: {{ block.settings.meta_color }};
  }

  .ai-journey-modal__comment-name-{{ ai_gen_id }} {
    font-weight: 700;
    color: {{ block.settings.text_color }};
  }

  .ai-journey-modal__comment-text-{{ ai_gen_id }} {
    margin: 0;
    font-size: 13px;
    line-height: 1.5;
    color: {{ block.settings.text_color }};
  }

  .ai-journey-modal__empty-{{ ai_gen_id }} {
    margin: 0 0 12px;
    font-size: 13px;
    color: {{ block.settings.meta_color }};
  }

  .ai-journey-modal__form-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 120px 1fr auto;
    gap: 8px;
  }

  .ai-journey-modal__input-{{ ai_gen_id }} {
    width: 100%;
    border: 1px solid rgba(0, 0, 0, 0.2);
    border-radius: 999px;
    padding: 10px 12px;
    font-size: 13px;
    background: #ffffff;
    color: {{ block.settings.text_color }};
  }

  .ai-journey-modal__submit-{{ ai_gen_id }} {
    border: 0;
    border-radius: 999px;
    background: {{ block.settings.accent_color }};
    color: #ffffff;
    font-size: 13px;
    font-weight: 700;
    padding: 10px 14px;
    cursor: pointer;
  }

  .ai-journey-create-{{ ai_gen_id }} {
    margin-top: 36px;
    background: {{ block.settings.card_background }};
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: {{ block.settings.card_radius }}px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  .ai-journey-create__header-{{ ai_gen_id }} {
    padding: 20px 24px 18px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.07);
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-journey-create__icon-{{ ai_gen_id }} {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: {{ block.settings.accent_color }};
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ai-journey-create__icon-{{ ai_gen_id }} svg {
    width: 18px;
    height: 18px;
    color: #ffffff;
    stroke: #ffffff;
  }

  .ai-journey-create__header-text-{{ ai_gen_id }} {
    min-width: 0;
  }

  .ai-journey-create__title-{{ ai_gen_id }} {
    margin: 0 0 2px;
    font-size: 17px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    line-height: 1.2;
  }

  .ai-journey-create__subtitle-{{ ai_gen_id }} {
    margin: 0;
    font-size: 13px;
    color: {{ block.settings.meta_color }};
    line-height: 1.4;
  }

  .ai-journey-create__body-{{ ai_gen_id }} {
    padding: 20px 24px 22px;
  }

  .ai-journey-create__form-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: auto 1fr 1fr 1.6fr auto;
    gap: 14px;
    align-items: end;
  }

  .ai-journey-create__group-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .ai-journey-create__label-{{ ai_gen_id }} {
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: {{ block.settings.meta_color }};
    font-weight: 700;
  }

  .ai-journey-create__input-{{ ai_gen_id }},
  .ai-journey-create__textarea-{{ ai_gen_id }} {
    width: 100%;
    border: 1.5px solid rgba(0, 0, 0, 0.13);
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 13.5px;
    color: {{ block.settings.text_color }};
    background: #fafafa;
    outline: none;
    transition: border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
  }

  .ai-journey-create__input-{{ ai_gen_id }}:focus,
  .ai-journey-create__textarea-{{ ai_gen_id }}:focus {
    border-color: {{ block.settings.accent_color }};
    background: #ffffff;
    box-shadow: 0 0 0 3px {{ block.settings.accent_color }}22;
  }

  .ai-journey-create__input-{{ ai_gen_id }}::placeholder,
  .ai-journey-create__textarea-{{ ai_gen_id }}::placeholder {
    color: rgba(0, 0, 0, 0.3);
  }

  .ai-journey-create__upload-zone-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    border: 1.5px dashed rgba(0, 0, 0, 0.18);
    border-radius: 10px;
    padding: 12px 16px;
    background: #fafafa;
    cursor: pointer;
    min-width: 110px;
    transition: border-color 0.18s ease, background 0.18s ease;
  }

  .ai-journey-create__upload-zone-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.accent_color }};
    background: #f5f5f2;
  }

  .ai-journey-create__upload-zone-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    color: {{ block.settings.meta_color }};
    stroke: {{ block.settings.meta_color }};
    flex-shrink: 0;
  }

  .ai-journey-create__upload-label-text-{{ ai_gen_id }} {
    font-size: 11.5px;
    font-weight: 600;
    color: {{ block.settings.meta_color }};
    white-space: nowrap;
  }

  .ai-journey-create__input-file-{{ ai_gen_id }} {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  .ai-journey-create__textarea-{{ ai_gen_id }} {
    min-height: 44px;
    max-height: 140px;
    resize: vertical;
  }

  .ai-journey-create__submit-{{ ai_gen_id }} {
    border: 0;
    border-radius: 999px;
    padding: 11px 22px;
    background: {{ block.settings.accent_color }};
    color: #ffffff;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
    letter-spacing: 0.02em;
    box-shadow: 0 2px 8px {{ block.settings.accent_color }}55;
    transition: opacity 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
  }

  .ai-journey-create__submit-{{ ai_gen_id }}:hover {
    opacity: 0.88;
    transform: translateY(-1px);
    box-shadow: 0 4px 14px {{ block.settings.accent_color }}66;
  }

  .ai-journey-create__submit-{{ ai_gen_id }}:active {
    transform: translateY(0);
    opacity: 1;
  }

  .ai-journey-create__status-{{ ai_gen_id }} {
    margin: 12px 0 0;
    font-size: 12px;
    color: {{ block.settings.meta_color }};
    min-height: 16px;
  }

  @media screen and (max-width: 1024px) {
    .ai-journey-posts__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .ai-journey-modal__panel-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      max-height: calc(100vh - 24px);
    }

    .ai-journey-modal__media-{{ ai_gen_id }} {
      max-height: 42vh;
    }

    .ai-journey-create__form-{{ ai_gen_id }} {
      grid-template-columns: auto 1fr 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-journey-posts-{{ ai_gen_id }} {
      padding: 18px 12px 38px;
    }

    .ai-journey-posts__header-{{ ai_gen_id }} {
      margin-bottom: 18px;
    }

    .ai-journey-posts__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .ai-journey-modal-{{ ai_gen_id }} {
      padding: 8px;
    }

    .ai-journey-modal__content-{{ ai_gen_id }} {
      padding: 14px;
    }

    .ai-journey-modal__title-{{ ai_gen_id }} {
      font-size: 20px;
    }

    .ai-journey-modal__form-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-journey-create-{{ ai_gen_id }} {
      margin-top: 20px;
    }

    .ai-journey-create__header-{{ ai_gen_id }} {
      padding: 16px 16px 14px;
    }

    .ai-journey-create__body-{{ ai_gen_id }} {
      padding: 16px 16px 18px;
    }

    .ai-journey-create__form-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<journey-posts-{{ ai_gen_id }} class="ai-journey-posts-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-journey-posts__container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank %}
      <div class="ai-journey-posts__header-{{ ai_gen_id }}">
        <h2 class="ai-journey-posts__title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
        {% if block.settings.section_subtitle != blank %}
          <p class="ai-journey-posts__subtitle-{{ ai_gen_id }}">{{ block.settings.section_subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% assign posts = '
      [
        {
          "author": "Sarah Mitchell",
          "initials": "SM",
          "date": "March 15, 2026",
          "title": "Sunrise Push at Ben Nevis",
          "description": "Chased sunrise to the summit and captured one of the clearest ridge views this season.",
          "detail": "We started before 4:00 AM and moved steady through changing weather. The final ascent was icy, but the sky opened just as we reached the top. This trip reminded me that timing, patience, and a strong team make all the difference on hard routes.",
          "image_url": "https://picsum.photos/seed/ro-blog-1/900/900",
          "likes": 127,
          "isLiked": true,
          "comments": [
            {"author": "James", "text": "That sunrise shot is unreal.", "date": "Mar 16"},
            {"author": "Emma", "text": "Adding this route to my list.", "date": "Mar 17"}
          ]
        },
        {
          "author": "Marcus Chen",
          "initials": "MC",
          "date": "March 18, 2026",
          "title": "Cornwall Coastal Switchbacks",
          "description": "Windy ridge line, rough terrain, and the bluest water I have seen this year.",
          "detail": "The western trail had steep switchbacks and loose stone sections, so poles were essential. We paused often because the cliff views were too good to rush. If you do this route, start early and pack layers for quick weather swings.",
          "image_url": "https://picsum.photos/seed/ro-blog-2/900/900",
          "likes": 93,
          "isLiked": false,
          "comments": [
            {"author": "Lucy", "text": "Looks like a perfect weekend run.", "date": "Mar 19"}
          ]
        },
        {
          "author": "Olivia Thompson",
          "initials": "OT",
          "date": "March 20, 2026",
          "title": "Highlands Wild Camp Setup",
          "description": "Three nights off-grid with cold mornings, clear nights, and incredible silence.",
          "detail": "Camped above the tree line with a low profile tent to handle wind exposure. The second night dropped below freezing, but the setup held and we woke up to a full valley cloud inversion. This is the kind of trip that resets your pace.",
          "image_url": "https://picsum.photos/seed/ro-blog-3/900/900",
          "likes": 156,
          "isLiked": true,
          "comments": [
            {"author": "Tom", "text": "What sleeping bag rating did you use?", "date": "Mar 21"},
            {"author": "Alex", "text": "Cloud inversion looks insane.", "date": "Mar 22"}
          ]
        },
        {
          "author": "David Roberts",
          "initials": "DR",
          "date": "March 22, 2026",
          "title": "Welsh Trail Bike Session",
          "description": "Fast descents, technical corners, and one very muddy finish line.",
          "detail": "The upper section was mostly rock gardens and tight turns, so speed control mattered more than power. We rode three loops and adjusted tire pressure between runs to improve grip. Legs were cooked by the last descent.",
          "image_url": "https://picsum.photos/seed/ro-blog-4/900/900",
          "likes": 104,
          "isLiked": false,
          "comments": [
            {"author": "Mike", "text": "Need the GPX for this route.", "date": "Mar 23"}
          ]
        },
        {
          "author": "Hannah Wilson",
          "initials": "HW",
          "date": "March 24, 2026",
          "title": "Windermere Kayak Drift",
          "description": "Glassy water before noon and mountain reflections all day.",
          "detail": "Started from the north shore and kept close to the lee side to avoid crosswind in open water. The lake stayed calm for most of the route, which made photography easy. Ended with a short portage and hot coffee by sunset.",
          "image_url": "https://picsum.photos/seed/ro-blog-5/900/900",
          "likes": 118,
          "isLiked": true,
          "comments": [
            {"author": "Rachel", "text": "This color palette is beautiful.", "date": "Mar 24"},
            {"author": "Chris", "text": "Morning water looked perfect.", "date": "Mar 25"}
          ]
        },
        {
          "author": "Priya Nair",
          "initials": "PN",
          "date": "March 25, 2026",
          "title": "Forest Loop Recovery Hike",
          "description": "Easy pace, long trail chat, and a lot of fern-lined paths.",
          "detail": "After two intense weekends, we planned a recovery day with lighter packs and frequent breaks. The route stayed mostly shaded and had several stream crossings that kept it cool throughout the afternoon. Sometimes slower is exactly right.",
          "image_url": "https://picsum.photos/seed/ro-blog-6/900/900",
          "likes": 79,
          "isLiked": false,
          "comments": [
            {"author": "Nico", "text": "Need more low-intensity routes like this.", "date": "Mar 26"}
          ]
        }
      ]
    ' | strip %}

    {% assign posts_array = posts | parse_json %}

    <div class="ai-journey-posts__grid-{{ ai_gen_id }}" data-posts-grid></div>

    <div class="ai-journey-modal-{{ ai_gen_id }}" data-post-modal aria-hidden="true">
      <div class="ai-journey-modal__panel-{{ ai_gen_id }}" role="dialog" aria-modal="true" aria-label="Blog post details">
        <div class="ai-journey-modal__media-{{ ai_gen_id }}" data-modal-media></div>

        <div class="ai-journey-modal__content-{{ ai_gen_id }}">
          <div class="ai-journey-modal__top-{{ ai_gen_id }}">
