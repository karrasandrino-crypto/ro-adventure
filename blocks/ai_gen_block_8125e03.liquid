{% doc %}
  @prompt
    create grid of 3 image with text overlay the image
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    margin: auto;
    padding-left: 5rem;
    padding-right: 5rem;
    padding-top: 13rem;
    padding-bottom: 5rem;
    background-color: #f9f6ef;
  }

  .ai-image-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-image-grid__item-{{ ai_gen_id }} {
    position: relative;
    overflow: visible;
    border-radius: {{ block.settings.border_radius }}px;
    aspect-ratio: {{ block.settings.aspect_ratio }};
  }

  .ai-image-grid__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-image-grid__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-grid__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-image-grid__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    font-size: 12px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-image-grid__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    pointer-events: none;
  }

  .ai-image-grid__text-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: end;
    align-items: {{ block.settings.text_horizontal_alignment }};
    padding: {{ block.settings.text_padding }}px;
    text-align: {{ block.settings.text_align }};
    z-index: 1;
  }

  .ai-image-grid__heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    margin: 0 0 8px 0;
    line-height: 1.2;
  }

  .ai-image-grid__subtext-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.subtext_size }}px;
    margin: 0;
    line-height: 1.4;
  }

  .c-width{
    max-width: var(--page-width);
    margin: auto;
  }

  .float-title{
    position: absolute;
    top: 0;
    left: 0;
    margin-top: -120px;
    width: 100%;
    text-align: center;
  }

  .m-title {
     color: #375937;
     margin-bottom: 0px;
     font-weight: 700;
     font-size: 2.7rem;
  }

  .m-desc {
     color: #375937;
     margin-bottom: 0px;
     margin-top: -10px;
  }

  .button-label {
    padding: 0.7rem 2rem;
    background-color: #f9f6ef;
    color: #375937;
    border-radius: 5px;
    font-size: 12px;
    font-weight: 500;
  }


  @media screen and (max-width: 749px) {
    .ai-image-grid__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.grid_gap | times: 0.75 }}px;
    }

    .gap-100{
      gap: 130px !important;
    }

    .ai-image-grid__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-image-grid__subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<image-grid-{{ ai_gen_id }} class="ai-image-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="c-width">
    <div class="ai-image-grid__container-{{ ai_gen_id }} gap-100">
      {% for i in (1..3) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign heading_key = 'heading_' | append: i
          assign subtext_key = 'subtext_' | append: i
          assign link_key = 'link_' | append: i

          assign image = block.settings[image_key]
          assign heading = block.settings[heading_key]
          assign subtext = block.settings[subtext_key]
          assign link = block.settings[link_key]
        %}

        {% if link != blank %}
          <a href="{{ link }}" class="ai-image-grid__item-{{ ai_gen_id }}">
        {% else %}
          <div class="ai-image-grid__item-{{ ai_gen_id }}">
        {% endif %}

          {% if image %}
            <div class="float-title">
              {% if heading != blank %}
                <p class="m-title">{{ heading }}</p>
              {% endif %}
             {% if subtext != blank %}
                <p class="m-desc">{{ subtext }}</p>
              {% endif %}
            </div>
            <img
              src="{{ image | image_url: width: 800 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="{{ image.width }}"
              height="{{ image.height }}"
              class="ai-image-grid__image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-image-grid__placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-image-grid__empty-state-{{ ai_gen_id }}">
                Add image {{ i }}
              </div>
            </div>
          {% endif %}

          <div class="ai-image-grid__overlay-{{ ai_gen_id }}"></div>

          {% if heading != blank or subtext != blank %}
            <div class="ai-image-grid__text-wrapper-{{ ai_gen_id }}">
              {% if heading != blank %}
                <p class="ai-image-grid__subtext-{{ ai_gen_id }} button-label">SHOP {{ heading }}</p>
              {% endif %}
            </div>
          {% endif %}

        {% if link != blank %}
          </a>
        {% else %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</image-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('image-grid-{{ ai_gen_id }}', ImageGrid{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Image grid with text",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
