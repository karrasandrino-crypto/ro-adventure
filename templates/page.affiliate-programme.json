 border: 1px solid #ccc; border-radius: 4px; font-size: 16px; box-sizing: border-box;\" placeholder=\"Your channel name or URL\">\n    </div>\n\n    <div style=\"margin-bottom: 20px;\">\n      <label for=\"other_social\" style=\"display: block; margin-bottom: 8px; font-weight: 600;\">Other Social Media</label>\n      <input type=\"text\" id=\"other_social\" name=\"other_social\" style=\"width: 100%; padding: 12px; border: 1px solid #ccc; border-radius: 4px; font-size: 16px; box-sizing: border-box;\" placeholder=\"Twitter, Facebook, LinkedIn, etc.\">\n    </div>\n\n    <div style=\"margin-bottom: 20px;\">\n      <label for=\"message\" style=\"display: block; margin-bottom: 8px; font-weight: 600;\">Message *</label>\n      <textarea id=\"message\" name=\"message\" required style=\"width: 100%; padding: 12px; border: 1px solid #ccc; border-radius: 4px; font-size: 16px; box-sizing: border-box; font-family: inherit; min-height: 150px;\" placeholder=\"Tell us about your affiliate interest and how you'd like to collaborate...\"></textarea>\n    </div>\n\n    <button type=\"submit\" style=\"background-color: #edb21c; color: #f9f6ef; padding: 14px 32px; border: none; border-radius: 4px; font-size: 16px; font-weight: 600; cursor: pointer; width: 100%; transition: opacity 0.3s ease;\">Send Application</button>\n  </form>\n</div>",
